---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";

export async function getStaticPaths() {
    const posts = await getCollection("posts");
    return posts.map((post) => ({
        params: { slug: post.id.replace(/\.mdx?$/, '') },
        props: { post },
    }));
}

const { post } = Astro.props;
const resolvedPost =
    post ??
    (await getCollection("posts")).find(
        (entry) => entry.id.replace(/\.mdx?$/, '') === Astro.params.slug
    );

if (!resolvedPost) {
    throw new Error(`Post not found for slug: ${Astro.params.slug}`);
}

const { Content } = await render(resolvedPost);
---
<BlogLayout>
    <Content />
</BlogLayout>
