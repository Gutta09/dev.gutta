<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="40" height="40">
  <!-- Robot head -->
  <rect x="20" y="20" width="60" height="50" rx="5" fill="#BB86FC" stroke="#ffffff" stroke-width="2"/>
  <!-- Left eye -->
  <circle cx="35" cy="35" r="6" fill="#ffffff"/>
  <!-- Right eye -->
  <circle cx="65" cy="35" r="6" fill="#ffffff"/>
  <!-- Mouth -->
  <path d="M 40 50 Q 50 55 60 50" stroke="#ffffff" stroke-width="2" fill="none"/>
  <!-- Body -->
  <rect x="30" y="75" width="40" height="20" fill="#AA336A"/>
  <!-- Arms -->
  <rect x="10" y="80" width="20" height="8" fill="#BB86FC"/>
  <rect x="70" y="80" width="20" height="8" fill="#BB86FC"/>
</svg>
