---
import Layout from '../layouts/Layout.astro';

const channels = [
  { label: 'Email', value: 'bhargavgutta910@gmail.com', href: 'mailto:bhargavgutta910@gmail.com' },
  { label: 'GitHub', value: 'github.com/Gutta09', href: 'https://github.com/Gutta09' },
  { label: 'LinkedIn', value: 'linkedin.com/in/bhargavgutta', href: 'https://www.linkedin.com/in/bhargavgutta/' },
  { label: 'LeetCode', value: 'leetcode.com/u/ySH4mNLSXa', href: 'https://leetcode.com/u/ySH4mNLSXa/' },
];
---
<Layout title="Contact · Bhargav Gutta" description="Get in touch with Bhargav Gutta.">
  <p class="section-label mb-4">Say hello</p>
  <h1 class="display-lg mb-4">Get in touch</h1>
  <p class="lead max-w-2xl mb-14">
    Whether you have a question, a project opportunity, or just want to say hi —
    my inbox is always open.
  </p>

  <div class="space-y-6">
    {channels.map((c, i) => (
      <a
        href={c.href}
        target={c.href.startsWith('mailto:') ? undefined : '_blank'}
        rel={c.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
        class={`tint-card tint-${i % 5} reveal grid sm:grid-cols-[160px_1fr_auto] gap-2 sm:gap-10 items-baseline group !py-8`}
      >
        <span class="section-label !before:hidden">{c.label}</span>
        <span class="display-md !text-[clamp(1.1rem,2.5vw,1.6rem)] break-all">{c.value}</span>
        <span class="hidden sm:inline card-accent text-2xl" aria-hidden="true">→</span>
      </a>
    ))}
  </div>
</Layout>
