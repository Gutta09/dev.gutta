---
import Layout from '../layouts/Layout.astro';
import { fetchPortfolioRepos, formatRepoName } from '../lib/github';

const repos = await fetchPortfolioRepos();
const noProjects = repos.length === 0;
---
<Layout title="Projects · Bhargav Gutta" description="Projects by Bhargav Gutta, auto-synced from GitHub.">
  <p class="section-label mb-4">Auto-synced from GitHub</p>
  <h1 class="display-lg mb-4">Projects</h1>
  <p class="lead max-w-2xl mb-14">
    Repos on
    <a href="https://github.com/Gutta09" target="_blank" rel="noopener noreferrer" class="underline underline-offset-4 hover:text-[var(--accent)]">my GitHub</a>
    tagged with the <code>portfolio</code> topic show up here automatically.
  </p>

  {noProjects ? (
    <p class="lead">
      No projects found right now. Check back soon, or browse
      <a href="https://github.com/Gutta09" target="_blank" rel="noopener noreferrer" class="underline underline-offset-4 hover:text-[var(--accent)]">GitHub</a> directly.
    </p>
  ) : (
    <div class="space-y-8">
      {repos.map((repo, i) => {
        const displayName = formatRepoName(repo.name);
        const visibleTopics = repo.topics.filter(t => t !== 'portfolio');
        const liveUrl = repo.homepage?.startsWith('http') ? repo.homepage : null;
        return (
          <article class={`tint-card tint-${i % 5} reveal`}>
            <div class="grid sm:grid-cols-[auto_1fr] gap-6 sm:gap-12 items-start">
              <span class="project-number">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <h2 class="display-md mb-3">{displayName}</h2>
                {repo.description && (
                  <p class="lead !text-[var(--text)] !opacity-75 max-w-2xl mb-5">{repo.description}</p>
                )}
                {(visibleTopics.length > 0 || repo.languages.length > 0) && (
                  <div class="flex flex-wrap gap-2 mb-6">
                    {repo.languages.map(lang => <span class="chip">{lang}</span>)}
                    {visibleTopics.slice(0, 5).map(topic => <span class="chip">{topic}</span>)}
                  </div>
                )}
                <div class="flex flex-wrap items-center gap-6">
                  <a href={repo.html_url} target="_blank" rel="noopener noreferrer" class="link-arrow card-accent">
                    View on GitHub <span aria-hidden="true">→</span>
                  </a>
                  {liveUrl && (
                    <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="link-arrow card-accent">
                      Live site <span aria-hidden="true">→</span>
                    </a>
                  )}
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  )}
</Layout>
