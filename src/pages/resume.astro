                    </p>
                </div>

                <!-- Education -->
                <div class="mt-6 w-full">
                    <h2 class="title-font dark:text-titlePurple dark:text-opacity-80 sm:text-2xl text-xl mb-3 font-semibold text-black">
                        EDUCATION
                    </h2>
                    <div class="dark:text-gray-400 text-gray-700 space-y-2">
                        <div class="flex justify-between items-start">
                            <div>
                                <h3 class="font-bold dark:text-gray-100">SRM University AP</h3>
                                <p class="italic">B.Tech. Computer Science and Engineering</p>
                            </div>
                            <span class="text-sm">Aug. 2023 – May 2027</span>
                        </div>
                        <p>📊 Cumulative GPA: 7.5/10</p>
                    </div>
                </div>

                <!-- Experience -->
                <div class="mt-6 w-full">
                    <h2 class="title-font dark:text-titlePurple dark:text-opacity-80 sm:text-2xl text-xl mb-3 font-semibold text-black">
                        EXPERIENCE
                    </h2>
                    <div class="dark:text-gray-400 text-gray-700 space-y-4">
                        <div>
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="font-bold dark:text-gray-100">Edubot Technologies</h3>
                                    <p class="italic text-sm">Full Stack Developer Intern (MERN Stack)</p>
                                </div>
                                <span class="text-sm">June 2025 – July 2025</span>
                            </div>
                            <ul class="list-disc list-inside mt-2 space-y-1 text-sm">
                                <li>Completed an intensive 8-week program focused on MERN stack development</li>
                                <li>Developed a full-stack Expense Tracker application with React + Vite and Node.js/Express.js</li>
                                <li>Implemented responsive UI, client-side routing, and RESTful APIs</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Projects -->
