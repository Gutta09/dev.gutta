---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resume · Bhargav Gutta" description="Bhargav Gutta's resume.">
  <div class="flex flex-wrap items-end justify-between gap-6 mb-12">
    <h1 class="display-lg">Resume</h1>
    <a href="/resume.pdf" download class="btn-solid">
      Download PDF ↓
    </a>
  </div>
  <div class="w-full h-[85vh] rounded-2xl overflow-hidden border border-[var(--border)]">
    <iframe
      src="/resume.pdf"
      title="Resume PDF"
      class="w-full h-full border-0"
    ></iframe>
  </div>
</Layout>
