---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <section id="resume" class="flex overflow-x-hidden pt-5">
        <div class="container mx-auto flex justify-center pb-20 text-lg leading-relaxed md:w-[80%] lg:w-[60%] flex-col items-start pt-3 space-y-3">
            <div class="flex flex-col items-start pt-3 pb-3 space-y-3 w-full">
                <h1 class="title-font dark:text-gray-100 dark:text-opacity-80 sm:text-4xl text-3xl mb-4 font-medium text-black py-2">
                    Gutta Bhargav Prudhvi
                </h1>
                
                <div class="text-sm dark:text-gray-400 text-gray-600 space-y-1 w-full">
                    <p>📧 bhargavgutta910@gmail.com</p>
                    <p>📱 +91 9502980009</p>
                    <p>🔗 <a href="https://github.com/Gutta09" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline">GitHub: Gutta09</a></p>
                    <p>💼 <a href="https://www.linkedin.com/in/bhargavgutta" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline">LinkedIn: Bhargavgutta</a></p>
                    <p>🌐 <a href="https://dev-gutta.vercel.app" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline">Portfolio Website</a></p>
