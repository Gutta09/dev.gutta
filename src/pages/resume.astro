                    <h2 class="title-font dark:text-titlePurple dark:text-opacity-80 sm:text-2xl text-xl mb-3 font-semibold text-black">
                        PROJECTS
                    </h2>
                    <div class="dark:text-gray-400 text-gray-700 space-y-6">
                        <!-- LearnWave -->
                        <div>
                            <div class="flex justify-between items-start">
                                <h3 class="font-bold dark:text-gray-100">Learn Wave</h3>
                                <a href="https://github.com/Gutta09/LearnWave" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline text-sm">GitHub</a>
                            </div>
                            <p class="text-sm italic mb-2">Next.js, TypeScript, PostgreSQL, OpenAI API</p>
                            <ul class="list-disc list-inside space-y-1 text-sm">
