                <!-- Skills -->
                <div class="mt-6 w-full">
                    <h2 class="title-font dark:text-titlePurple dark:text-opacity-80 sm:text-2xl text-xl mb-3 font-semibold text-black">
                        SKILLS
                    </h2>
                    <div class="dark:text-gray-400 text-gray-700 space-y-2 text-sm">
                        <p><span class="font-semibold dark:text-gray-100">Languages:</span> Python, JavaScript, HTML/CSS, SQL, Go</p>
                        <p><span class="font-semibold dark:text-gray-100">Frameworks:</span> React.js, Node.js, Express.js, Tailwind CSS, Astro</p>
