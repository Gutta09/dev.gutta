                        <div>
                            <div class="flex justify-between items-start">
                                <h3 class="font-bold dark:text-gray-100">Expense Tracker</h3>
                                <a href="https://github.com/Gutta09/ExpenseTracker" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline text-sm">GitHub</a>
                            </div>
                            <p class="text-sm italic mb-2">React, Vite, Tailwind CSS, Node.js, Express.js, MongoDB</p>
                            <ul class="list-disc list-inside space-y-1 text-sm">
                                <li>Architected a secure full-stack MERN application with JWT authentication and role-based access control</li>
                                <li>Implemented centralized state management using React Context API with real-time dashboard updates</li>
                                <li>Built and documented RESTful APIs with modular controllers and middleware</li>
                            </ul>
                        </div>

                        <!-- RhythmicTunes -->
                        <div>
                            <div class="flex justify-between items-start">
                                <h3 class="font-bold dark:text-gray-100">RhythmicTunes</h3>
                                <a href="https://github.com/Gutta09/RhythmicTunes" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline text-sm">GitHub</a>
                            </div>
                            <p class="text-sm italic mb-2">React, Tailwind CSS, Shadcn/ui, Vite</p>
