---
import { fetchPortfolioRepos, formatRepoName } from '../lib/github';
import staticProjects from '../data/projects.js';

const githubRepos = await fetchPortfolioRepos();

// Hand-picked flagship projects for the home page, strongest first.
// Everything else still shows on /projects.
const FEATURED = ['fin-fraud-shield', 'ferrum', 'fitero', 'courses', 'xpensit'];
const featuredRepos = FEATURED
  .map(name => githubRepos.find(r => r.name.toLowerCase() === name))
  .filter(r => r !== undefined);
const heroRepos = featuredRepos.length > 0 ? featuredRepos : githubRepos.slice(0, 4);

// Use GitHub repos if available, otherwise fall back to static data
const projects = heroRepos.length > 0
  ? heroRepos.map(r => ({
      name: formatRepoName(r.name),
      description: r.description ?? '',
      url: r.html_url,
      live: r.homepage?.startsWith('http') ? r.homepage : null,
      languages: r.languages,
      topics: r.topics.filter(t => t !== 'portfolio'),
    }))
  : staticProjects.map((p: { title: string; description: string; link: string }) => ({
      name: p.title,
      description: p.description,
      url: p.link,
      live: null,
      languages: [],
      topics: [],
    }));

const skillsA = ['JavaScript', 'TypeScript', 'Python', 'SQL', 'React', 'Next.js', 'Node.js', 'Express.js', 'Astro'];
const skillsB = ['MongoDB', 'PostgreSQL', 'MySQL', 'Tailwind CSS', 'AWS Lambda', 'Git', 'Vercel', 'OpenAI API', 'REST APIs'];
---

<!-- Hero -->
<section class="pt-8 sm:pt-16 pb-20 sm:pb-28">
  <div>
    <div>
      <p class="section-label mb-6">Full Stack Developer · CS @ SRM University AP</p>
      <h1 class="display-xl mb-8">
        Bhargav <span class="aurora-text">here!</span> <span class="wave">👋</span>
      </h1>
      <p class="lead max-w-2xl mb-10">
        I build full-stack web applications and enjoy integrating AI into products.
        I like working on projects that actually ship, and I keep my problem-solving
        sharp on LeetCode. Outside of code — gym, reading, and video games.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a href="mailto:bhargavgutta910@gmail.com" class="btn-solid">Get in touch</a>
        <a href="/resume.pdf" download class="btn-outline">Resume ↓</a>
      </div>
      <div class="flex items-center gap-8 mt-10">
        <a href="https://github.com/Gutta09" target="_blank" rel="noopener noreferrer" class="soft-link">GitHub</a>
        <a href="https://www.linkedin.com/in/bhargavgutta/" target="_blank" rel="noopener noreferrer" class="soft-link">LinkedIn</a>
        <a href="https://leetcode.com/u/ySH4mNLSXa/" target="_blank" rel="noopener noreferrer" class="soft-link">LeetCode</a>
      </div>
    </div>
  </div>
</section>

<!-- Skills marquee -->
<section class="pb-20 sm:pb-28 reveal">
  <div class="marquee mb-4">
    <div class="marquee-track">
      {[...skillsA, ...skillsA].map(skill => <span class="pill">{skill}</span>)}
    </div>
  </div>
  <div class="marquee">
    <div class="marquee-track reverse">
      {[...skillsB, ...skillsB].map(skill => <span class="pill">{skill}</span>)}
    </div>
  </div>
</section>

<!-- Work -->
<section id="work" class="pb-20 sm:pb-28 scroll-mt-28">
  <div class="reveal">
    <p class="section-label mb-4">Flagship projects</p>
    <h2 class="display-lg mb-14">My Work</h2>
  </div>

  <div class="space-y-8">
    {projects.map((project, i) => (
      <article class={`tint-card tint-${i % 5} reveal`}>
        <div class="grid sm:grid-cols-[auto_1fr] gap-6 sm:gap-12 items-start">
          <span class="project-number">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3 class="display-md mb-3">{project.name}</h3>
            {project.description && (
              <p class="lead !text-[var(--text)] !opacity-75 max-w-2xl mb-5">{project.description}</p>
            )}
            {(project.topics.length > 0 || project.languages.length > 0) && (
              <div class="flex flex-wrap gap-2 mb-6">
                {project.languages.map(lang => <span class="chip">{lang}</span>)}
                {project.topics.slice(0, 4).map(topic => <span class="chip">{topic}</span>)}
              </div>
            )}
            <div class="flex flex-wrap items-center gap-6">
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="link-arrow card-accent">
                View on GitHub <span aria-hidden="true">→</span>
              </a>
              {project.live && (
                <a href={project.live} target="_blank" rel="noopener noreferrer" class="link-arrow card-accent">
                  Live site <span aria-hidden="true">→</span>
                </a>
              )}
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="mt-12 flex justify-center reveal">
    <a href="/projects" class="btn-outline">See all projects →</a>
  </div>
</section>

<!-- Experience -->
<section class="pb-20 sm:pb-28">
  <div class="reveal">
    <p class="section-label mb-4">Where I've worked</p>
    <h2 class="display-lg mb-14">Experience</h2>
  </div>
  <div class="exp-card reveal">
    <div class="flex flex-wrap items-baseline justify-between gap-3 mb-2">
      <h3 class="display-md">Edubot Technologies</h3>
      <span class="section-label !normal-case !tracking-normal">Jun – Jul 2025</span>
    </div>
    <p class="text-[var(--text-muted)] mb-6" style="font-family: var(--font-heading)">Full Stack Developer Intern · Remote</p>
    <ul class="space-y-2 lead max-w-3xl list-disc pl-5">
      <li>Completed an 8-week MERN stack program (MongoDB, Express, React, Node.js).</li>
      <li>Built a full-stack Expense Tracker with JWT auth, RBAC, and a real-time dashboard.</li>
      <li>Implemented RESTful APIs, client-side routing, and CSV export with React Context API.</li>
    </ul>
  </div>
</section>

<!-- Education -->
<section>
  <div class="reveal">
    <p class="section-label mb-4">Where I study</p>
    <h2 class="display-lg mb-14">Education</h2>
  </div>
  <div class="exp-card reveal">
    <div class="flex flex-wrap items-baseline justify-between gap-3 mb-2">
      <h3 class="display-md">SRM University AP</h3>
      <span class="section-label !normal-case !tracking-normal">2023 – 2027</span>
    </div>
    <p class="text-[var(--text-muted)]" style="font-family: var(--font-heading)">
      B.Tech, Computer Science &amp; Engineering · Amaravathi, India · GPA 7.54 / 10
    </p>
  </div>
</section>
