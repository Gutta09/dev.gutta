---
// Curated flagship work — three projects, each with a real in-app screenshot.
const projects = [
  {
    name: 'PriceIQ',
    kind: 'Optimization · Operations Research',
    description:
      'Airline fare optimization: an OR-Tools mixed-integer program prices three cabins jointly under a shared aircraft-capacity constraint, on demand curves grounded in real DGCA market data. 27 tests, green CI.',
    image: '/work/priceiq.png',
    tech: ['FastAPI', 'OR-Tools', 'React', 'Python'],
    url: 'https://github.com/Gutta09/priceIQ',
    live: null,
  },
  {
    name: 'Studium AI',
    kind: 'AI Agent',
    description:
      'An adaptive study agent — upload a syllabus, get a plan and quizzes, and it re-plans around the topics your quizzes show you are weak on. Real agentic loop, JWT auth with per-user isolation, verified end-to-end against a live model.',
    image: '/work/studium.png',
    tech: ['FastAPI', 'React', 'Groq · Llama 3.3', 'MongoDB'],
    url: 'https://github.com/Gutta09/studium-ai',
    live: null,
  },
  {
    name: 'Ferrum',
    kind: 'Product · Full-stack',
    description:
      'A quiet, fast workout log — type “bench 3×8 @ 80” and it parses into sets, with your previous numbers and a live plate-loading breakdown on every row. Owner-scoped data, unit-tested training math, ships to iOS via Capacitor.',
    image: '/work/ferrum.png',
    tech: ['Next.js', 'TypeScript', 'MongoDB', 'Capacitor · iOS'],
    url: 'https://github.com/Gutta09/ferrum',
    live: 'https://workout-tracker-iota-weld.vercel.app',
  },
];

// Lighter grid of secondary projects — no screenshots, links out to source.
const moreProjects = [
  {
    name: 'LearnWave',
    kind: 'AI Course Generator',
    description:
      'Turn any topic into a full course — AI-written lessons and quizzes with curated YouTube videos and a progress heatmap.',
    tech: ['Next.js', 'MongoDB', 'OpenAI'],
    url: 'https://github.com/Gutta09/courses',
    live: 'https://courses-sigma-pink.vercel.app',
  },
  {
    name: 'ResAI',
    kind: 'RAG · Research Assistant',
    description:
      'Multi-document research assistant — ask questions across a corpus and get cited answers via a FAISS-backed retrieval pipeline.',
    tech: ['FastAPI', 'LangChain', 'FAISS', 'React'],
    url: 'https://github.com/Gutta09/resai',
    live: null,
  },
  {
    name: 'Emla',
    kind: 'ML · Accessibility',
    description:
      'Real-time ASL sign-language recognition from webcam landmarks, with a Transformer classifier and Gemini for phrasing.',
    tech: ['MediaPipe', 'Transformer', 'Gemini'],
    url: 'https://github.com/Gutta09/Emla',
    live: null,
  },
  {
    name: 'Progresso',
    kind: 'Project Management',
    description:
      'A full-stack project and task manager with boards and a typed FastAPI backend behind a Vite frontend.',
    tech: ['FastAPI', 'React', 'Vite'],
    url: 'https://github.com/Gutta09/progresso',
    live: null,
  },
  {
    name: 'Expensify',
    kind: 'AI Fintech',
    description:
      'Expense tracker with ML anomaly detection, budget forecasting, Power BI dashboards, and PDF export.',
    tech: ['MERN', 'Python', 'Power BI'],
    url: 'https://github.com/Gutta09/expensify',
    live: null,
  },
];

const skillsA = ['JavaScript', 'TypeScript', 'Python', 'SQL', 'React', 'Next.js', 'Node.js', 'Express.js', 'Astro'];
const skillsB = ['MongoDB', 'PostgreSQL', 'MySQL', 'Tailwind CSS', 'AWS Lambda', 'Git', 'Vercel', 'OpenAI API', 'REST APIs'];
---

<!-- Hero -->
<section class="pt-8 sm:pt-16 pb-20 sm:pb-28">
  <div>
    <div>
      <p class="section-label mb-6">Full Stack Developer · CS @ SRM University AP</p>
      <h1 class="display-xl mb-8">
        Bhargav <span class="hl">here!</span> <span class="wave">👋</span>
      </h1>
      <p class="lead max-w-2xl mb-10">
        I build full-stack web applications and enjoy integrating AI into products.
        I like working on projects that actually ship, and I keep my problem-solving
        sharp on LeetCode. Outside of code — gym, reading, and video games.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a href="mailto:bhargavgutta910@gmail.com" class="btn-solid">Get in touch</a>
        <a href="/resume.pdf" download class="btn-outline">Resume ↓</a>
      </div>
      <div class="flex items-center gap-8 mt-10">
        <a href="https://github.com/Gutta09" target="_blank" rel="noopener noreferrer" class="soft-link">GitHub</a>
        <a href="https://www.linkedin.com/in/bhargavgutta/" target="_blank" rel="noopener noreferrer" class="soft-link">LinkedIn</a>
        <a href="https://leetcode.com/u/ySH4mNLSXa/" target="_blank" rel="noopener noreferrer" class="soft-link">LeetCode</a>
      </div>
    </div>
  </div>
</section>

<!-- Skills marquee -->
<section class="pb-20 sm:pb-28 reveal">
  <div class="marquee mb-4">
    <div class="marquee-track">
      {[...skillsA, ...skillsA].map(skill => <span class="pill">{skill}</span>)}
    </div>
  </div>
  <div class="marquee">
    <div class="marquee-track reverse">
      {[...skillsB, ...skillsB].map(skill => <span class="pill">{skill}</span>)}
    </div>
  </div>
</section>

<!-- Work -->
<section id="work" class="pb-20 sm:pb-28 scroll-mt-28">
  <div class="reveal">
    <p class="section-label mb-4">Flagship projects</p>
    <h2 class="display-lg mb-14">My Work</h2>
  </div>

  <div class="space-y-8">
    {projects.map((project, i) => (
      <article class={`tint-card tint-${i % 5} reveal`}>
        <div class="work-shot mb-8">
          <img src={project.image} alt={`${project.name} — screenshot of the running app`} loading="lazy" width="1200" />
        </div>
        <div class="grid sm:grid-cols-[auto_1fr] gap-6 sm:gap-12 items-start">
          <span class="project-number">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <p class="section-label mb-3 card-accent">{project.kind}</p>
            <h3 class="display-md mb-3">{project.name}</h3>
            <p class="lead !text-[var(--text)] !opacity-75 max-w-2xl mb-5">{project.description}</p>
            <div class="flex flex-wrap gap-2 mb-6">
              {project.tech.map(t => <span class="chip">{t}</span>)}
            </div>
            <div class="flex flex-wrap items-center gap-6">
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="link-arrow card-accent">
                View on GitHub <span aria-hidden="true">→</span>
              </a>
              {project.live && (
                <a href={project.live} target="_blank" rel="noopener noreferrer" class="link-arrow card-accent">
                  Live site <span aria-hidden="true">→</span>
                </a>
              )}
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="mt-12 flex justify-center reveal">
    <a href="https://github.com/Gutta09" target="_blank" rel="noopener noreferrer" class="btn-outline">More on GitHub →</a>
  </div>
</section>

<style>
  .work-shot {
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--card-border, rgba(0,0,0,0.08));
    box-shadow: 0 10px 30px -12px var(--card-shadow, rgba(0,0,0,0.25));
    background: var(--bg);
    line-height: 0;
  }
  .work-shot img {
    display: block;
    width: 100%;
    height: auto;
  }
</style>

<!-- More projects -->
<section id="projects" class="pb-20 sm:pb-28 scroll-mt-28">
  <div class="reveal">
    <p class="section-label mb-4">Also worth a look</p>
    <h2 class="display-lg mb-14">More Projects</h2>
  </div>

  <div class="grid sm:grid-cols-2 gap-5 sm:gap-6">
    {moreProjects.map(project => (
      <article class="mini-card reveal">
        <div>
          <p class="section-label mb-3 mini-accent">{project.kind}</p>
          <h3 class="display-md !text-2xl mb-3">{project.name}</h3>
          <p class="lead !text-[var(--text)] !opacity-70 !text-base mb-5">{project.description}</p>
          <div class="flex flex-wrap gap-2 mb-6">
            {project.tech.map(t => <span class="chip !bg-[var(--bg)]">{t}</span>)}
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-6">
          <a href={project.url} target="_blank" rel="noopener noreferrer" class="link-arrow mini-accent">
            Source <span aria-hidden="true">→</span>
          </a>
          {project.live && (
            <a href={project.live} target="_blank" rel="noopener noreferrer" class="link-arrow mini-accent">
              Live <span aria-hidden="true">→</span>
            </a>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .mini-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 1.5rem;
    padding: clamp(24px, 3vw, 34px);
    height: 100%;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .mini-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 48px var(--card-shadow);
    border-color: var(--accent);
  }
  .mini-accent { color: var(--accent); }
</style>

<!-- Experience -->
<section class="pb-20 sm:pb-28">
  <div class="reveal">
    <p class="section-label mb-4">Where I've worked</p>
    <h2 class="display-lg mb-14">Experience</h2>
  </div>
  <div class="exp-card reveal">
    <div class="flex flex-wrap items-baseline justify-between gap-3 mb-2">
      <h3 class="display-md">Edubot Technologies</h3>
      <span class="section-label !normal-case !tracking-normal">Jun – Jul 2025</span>
    </div>
    <p class="text-[var(--text-muted)] mb-6" style="font-family: var(--font-heading)">Full Stack Developer Intern · Remote</p>
    <ul class="space-y-2 lead max-w-3xl list-disc pl-5">
      <li>Completed an 8-week MERN stack program (MongoDB, Express, React, Node.js).</li>
      <li>Built a full-stack Expense Tracker with JWT auth, RBAC, and a real-time dashboard.</li>
      <li>Implemented RESTful APIs, client-side routing, and CSV export with React Context API.</li>
    </ul>
  </div>
</section>

<!-- Education -->
<section>
  <div class="reveal">
    <p class="section-label mb-4">Where I study</p>
    <h2 class="display-lg mb-14">Education</h2>
  </div>
  <div class="exp-card reveal">
    <div class="flex flex-wrap items-baseline justify-between gap-3 mb-2">
      <h3 class="display-md">SRM University AP</h3>
      <span class="section-label !normal-case !tracking-normal">2023 – 2027</span>
    </div>
    <p class="text-[var(--text-muted)]" style="font-family: var(--font-heading)">
      B.Tech, Computer Science &amp; Engineering · Amaravathi, India · GPA 7.54 / 10
    </p>
  </div>
</section>
