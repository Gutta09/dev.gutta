---
import '../styles/global.css';
import { getCollection } from "astro:content";
// @ts-ignore
const postEntries = await getCollection("posts");
const text = "Hi, I'm Bhargav.";
const letters = [...text];
const subheader = "Full Stack Developer";
const subLetters = [...subheader];
import projects from '../data/projects.js';
---
<section id="about" class="flex justify-center overflow-x-hidden pb-16 pt-5 items-start h-screen md:ml-[5%] sm:ml-[4%] lg:ml-[8%]">

  <div class="container mx-auto flex justify-center">
    <div class="md:w-[60%] flex flex-col items-start pt-2 space-y-2"> 

        
        <h1 class="title-font m-0 sm:text-4xl dark:text-opacity-80 text-3xl font-medium dark:text-titlePurple text-black flex items-center"> 
            <span class="flex flex-wrap">  
              {letters.map((letter, index) => (
                <span 
                  class="fade-in-letter" 
                  style={`animation-delay: ${index * 0.1}s;`}
                >
                  {letter === ' ' ? '\u00A0' : letter} 
                </span>
              ))}
            </span>
            <img src="/mini.gif" alt="mini" class="w-12 h-12 ml-3 inline-block" />
          </h1>

          <h1 class="title-font m-0 sm:text-4xl dark:text-opacity-80 text-3xl mb-4 font-medium dark:text-titlePurple text-black flex items-center">
            <span class="flex flex-wrap">
                {subLetters.map((letter,index) => (
                    <span
                        class="fade-in-letter"
                        style={`animation-delay: ${(letters.length + index) * 0.1 + 1}s;`}
                    >
                        {letter === ' ' ? '\u00A0' : letter}
                    </span>
                ))}
            </span>
          </h1>

          <p class = "text-xl dark:text-opacity-70 dark:text-gray-300"> <b> Currently reading: </b> <em>The Silent Patient.</em> </p>
          <p class="leading-relaxed text-left dark:text-opacity-70 dark:text-gray-300 text-lg mb-4">
            <b>Hobbies:</b> gym, reading, coding, video games — and I love dogs.
          </p>
          <p class="leading-relaxed text-left dark:text-opacity-70 dark:text-gray-300 text-lg mb-6">
            Check out my LeetCode solutions <a href="https://leetcode.com/u/ySH4mNLSXa/" target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:underline">check out them here.</a>
          </p>
          <div class="flex py-2">
            <a
              href="mailto:bhargavgutta910@gmail.com"
              class="inline-flex text-white dark:bg-byz dark:hover:bg-containerGray dark:hover:text-white dark:text-white dark:text-opacity-90 bg-gray-700 border-0 py-2 px-6 focus:outline-none hover:bg-black rounded text-lg">
              Contact Me
            </a>
            <a
              href="/projects"
              class="ml-4 inline-flex dark:bg-opacity-80 dark:bg-gray-300 dark:hover:bg-containerGray bg-gray-300 border-0 py-2 px-6 dark:text-opacity-90 focus:outline-none hover:bg-gray-700 hover:text-white rounded text-lg">
              All Projects
            </a>
          </div>
          <div class="leading-relaxed lg:max-w-lg font-medium text-xl inline-flex bg-opacity-40 p-8 rounded py-2">
          </div>

          <h2 class="title-font sm:text-4xl text-3xl mb-8 font-medium dark:text-opacity-80 dark:text-gray-100 text-black py-2">
           Latest Projects
        </h2>
        

<div>
  {projects.slice(0,2).map(project => (
      <a href={project.link} target="_blank" rel="noopener noreferrer" class="block mb-6 shadow-lg hover:shadow-xl transition-transform duration-300 ease-in-out transform hover:scale-105">
          <div class="parallax flex dark:bg-containerGray bg-gray-50 px-2 py-4 rounded-xl overflow-hidden">
              <div class="w-1/3 border-r rounded-lg border-black border-2">
                  <img src={project.image} alt={project.title} class="w-full rounded-md h-full object-cover"/>
              </div>
              <div class="w-2/3 p-6">
                  <h3 class="text-xl dark:text-titlePurple dark:text-opacity-80 font-semibold mb-2">{project.title} <b class="dark:text-opacity-80 dark:text-gray-100">{project.status}</b></h3>
                  <p class="dark:text-gray-400 dark:text-opacity:70 text-gray-600 hidden lg:block">{project.description}</p>
                <p class="dark:text-gray-400 dark:text-opacity:70 text-gray-600 hidden md:block lg:hidden">{project.description.substring(0, 100)}...</p>
                <p class="dark:text-gray-400 dark:text-opacity:70 text-gray-600 hidden sm:block lg:hidden md:hidden">{project.description.substring(0, 40)}...</p>
              </div>
          </div>
      </a>
  ))}
</div>
  
  <h2 class="title-font dark:text-gray-100 dark:text-opacity-80 sm:text-4xl text-3xl mb-4 font-medium text-black py-2">
    Latest Blogs
  </h2>
  {postEntries.slice(0,2).map(blog => (
    // @ts-ignore
    <a href={`/posts/${blog.slug}`} class="block mb-8 shadow-lg hover:shadow-xl transition-transform duration-300 ease-in-out transform hover:scale-105">
      <div class="parallax flex dark:bg-containerGray px-2 bg-gray-50 py-4 mt-3 rounded-xl overflow-hidden">

        <div class="w-1/3 border-r rounded-lg border-black border-2">
          {/* @ts-ignore */}
          <img src={blog.data.image} alt={blog.data.title} class="w-full rounded-md h-full object-cover" />
        </div>

        <div class="w-2/3 p-6">
          {/* @ts-ignore */}
          <h3 class="text-xl font-semibold dark:text-opacity-80 dark:text-titlePurple mb-2">{blog.data.title}</h3>
          {/* @ts-ignore */}
          <h2 class="text-lg font-semibold pb-1 mb-2 dark:text-opacity-80 dark:text-gray-200">{blog.data.date}</h2>
          {/* @ts-ignore */}
          <p class="dark:text-gray-400 dark:text-opacity:70 text-gray-600 hidden lg:block">{blog.data.description}</p>
          {/* @ts-ignore */}
          <p class="dark:text-gray-400 dark:text-opacity:70 text-gray-600 hidden md:block lg:hidden">{blog.data.description.substring(0, 100)}...</p>
          {/* @ts-ignore */}
          <p class="dark:text-gray-400 dark:text-opacity:70 text-gray-600 hidden sm:block lg:hidden md:hidden">{blog.data.description.substring(0, 40)}...</p>

        </div>
      </div>
    </a>
  ))}

  <h2 class="title-font dark:text-gray-100 dark:text-opacity-80 mt-2 sm:text-4xl text-3xl mb-4 font-medium text-black pt-2">
    Gbot
  </h2>
  <h4 class="title-font dark:text-gray-100 dark:text-opacity-80 sm:text-xl text-lg mb-4 font-medium text-black">
    Powered by OpenAI and LangChain
  </h4>
  
  <!-- Chat Container -->
  <div class="chatbot-container block w-full max-w-2xl mb-8 mt-4 rounded-xl overflow-hidden shadow-lg">
    
    <!-- Chat Messages Area -->
    <div id="chat-messages" class="chat-messages dark:bg-containerGray bg-gray-50 px-4 py-4 space-y-4 max-h-96 overflow-y-auto">
      <!-- Bot Welcome Message -->
      <div class="flex items-start space-x-3">
        <img src="/gbot.gif" alt="Gbot" class="w-8 h-8 rounded-full flex-shrink-0" />
        <div class="chat-msg-bot dark:bg-lighterGray bg-gray-200 rounded-2xl rounded-tl-sm px-4 py-3 max-w-[85%]">
          <p class="text-sm dark:text-gray-200 text-gray-800">
            Hi! I'm <strong class="dark:text-gray-100 text-gray-900">Gbot</strong>. Ask me anything about Bhargav — his projects, skills, hobbies, or anything else!
          </p>
        </div>
      </div>
    </div>

    <!-- Loading Indicator -->
    <div id="loading-div" class="hidden dark:bg-containerGray bg-gray-50 px-4 py-2">
      <div class="flex items-start space-x-3">
        <img src="/gbot.gif" alt="Gbot" class="w-8 h-8 rounded-full flex-shrink-0" />
        <div class="dark:bg-lighterGray bg-gray-200 rounded-2xl rounded-tl-sm px-4 py-3">
          <div class="typing-indicator">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Input Area -->
    <div class="chat-input-area dark:bg-lighterGray bg-gray-100 px-4 py-3 border-t dark:border-gray-700 border-gray-300">
      <div class="flex items-center space-x-3">
        <input 
          id="user-question" 
          class="flex-1 border dark:border-gray-600 border-gray-300 dark:bg-containerGray bg-white dark:text-gray-200 text-gray-800 rounded-full px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-400 dark:focus:ring-gray-500 focus:border-transparent transition-all duration-200" 
          type="text" 
          placeholder="Ask me anything about Bhargav..."
          autocomplete="off"
        >
        <button 
          id="fetch-langchain-response" 
          class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-700 hover:bg-gray-600 dark:bg-gray-500 dark:hover:bg-gray-400 text-white transition-all duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 dark:focus:ring-offset-containerGray disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none"
          aria-label="Send message"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </button>
      </div>
      <p class="text-xs dark:text-gray-500 text-gray-400 mt-2 text-center">Powered by OpenAI & LangChain • AWS Lambda</p>
    </div>
  </div>

</div>
</div>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
      const fetchButton = document.getElementById('fetch-langchain-response');
      const userQuestion = document.getElementById('user-question') as HTMLInputElement | null;
      const chatMessages = document.getElementById('chat-messages');
      const loadingDiv = document.getElementById('loading-div');

      // ============================================================
      // IMPORTANT: Replace this URL with your actual API Gateway URL
      // after deploying the Lambda function.
      // ============================================================
      const API_ENDPOINT = "YOUR_API_GATEWAY_URL_HERE";

      function addUserMessage(text: string) {
        if (!chatMessages) return;
        const msgDiv = document.createElement('div');
        msgDiv.className = 'flex items-start space-x-3 justify-end';
        msgDiv.innerHTML = `
          <div class="chat-msg-user bg-gray-800 dark:bg-gray-200 rounded-2xl rounded-tr-sm px-4 py-3 max-w-[85%]">
            <p class="text-sm text-white dark:text-gray-800">${escapeHtml(text)}</p>
          </div>
          <div class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-600 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 dark:text-gray-300 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
        `;
        chatMessages.appendChild(msgDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }

      function addBotMessage(text: string) {
        if (!chatMessages) return;
        const msgDiv = document.createElement('div');
        msgDiv.className = 'flex items-start space-x-3 chat-msg-appear';
        msgDiv.innerHTML = `
          <img src="/gbot.gif" alt="Gbot" class="w-8 h-8 rounded-full flex-shrink-0" />
          <div class="chat-msg-bot dark:bg-lighterGray bg-gray-200 rounded-2xl rounded-tl-sm px-4 py-3 max-w-[85%]">
            <p class="text-sm dark:text-gray-200 text-gray-800">${escapeHtml(text)}</p>
          </div>
        `;
        chatMessages.appendChild(msgDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }

      function escapeHtml(text: string): string {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }

      async function handleSend() {
        const question = userQuestion ? userQuestion.value.trim() : '';
        
        if (!question) return;
        
        // Add user message to chat
        addUserMessage(question);
        if (userQuestion) userQuestion.value = '';

        // Show loading
        if (loadingDiv) loadingDiv.classList.remove('hidden');
        if (fetchButton) (fetchButton as HTMLButtonElement).disabled = true;

        try {
          const response = await fetch(API_ENDPOINT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ question }),
          });

          if (loadingDiv) loadingDiv.classList.add('hidden');

          if (response.ok) {
            const data = await response.json();
            addBotMessage(data.text);
          } else {
            addBotMessage("Sorry, I couldn't process your question right now. Please try again later.");
          }
        } catch (error) {
          console.error("Error:", error);
          if (loadingDiv) loadingDiv.classList.add('hidden');
          addBotMessage("Sorry, there was a connection error. Please try again.");
        }

        if (fetchButton) (fetchButton as HTMLButtonElement).disabled = false;
      }

      // Click handler
      if (fetchButton) {
        fetchButton.addEventListener('click', handleSend);
      }

      // Enter key handler
      if (userQuestion) {
        userQuestion.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            handleSend();
          }
        });
      }
    });
    </script>
</section>
